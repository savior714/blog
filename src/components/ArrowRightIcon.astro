---
interface Props {
  className?: string;
}

const { className = '' } = Astro.props;
---

<svg
  class={className}
  width="16"
  height="16"
  viewBox="0 0 16 16"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <path
    d="M3.5 8H12.5M12.5 8L8.75 4.25M12.5 8L8.75 11.75"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
</svg>
