---
import Layout from '../../components/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const cases = await getCollection('cases');
  return cases.map((entry) => ({
    params: { slug: entry.slug },
    props: {
      tag: entry.data.tag,
      title: entry.data.title,
      summary: entry.data.summary,
      publishedAt: entry.data.publishedAt,
      youtubeUrl: entry.data.youtubeUrl || '',
      thumbnail: entry.data.thumbnail || '',
      content: entry.body,
    },
  }));
}

const { tag, title, summary, publishedAt, youtubeUrl, thumbnail, content } = Astro.props;

function escapeHtml(text) {
  return text
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#039;');
}
---

<Layout title={`${title} | Savior Lab Notes`} description={summary}>
  <div class="admin-page">
    <nav class="admin-nav">
      <a href="/" class="admin-nav-brand">Savior Lab Notes</a>
      <div class="admin-nav-links">
        <a href="/case">Cases</a>
        <a href="/admin">Editor</a>
      </div>
    </nav>

    <article class="case-article">
      <a href="/case" class="back-link">← Cases</a>

      <header class="article-header">
        <span class="article-tag">{tag}</span>
        <h1>{title}</h1>
        <div class="article-meta">
          <time>{publishedAt}</time>
          {youtubeUrl && (
            <a href={youtubeUrl} target="_blank" rel="noreferrer">YouTube ↗</a>
          )}
        </div>
      </header>

      {thumbnail && (
        <div class="detail-thumb-wrap">
          <img src={thumbnail} alt={title} class="detail-thumb" />
        </div>
      )}

      <div class="article-content">
        {content.split('\n\n')
          .filter(Boolean)
          .map((p) => `<p>${escapeHtml(p)}</p>`)
          .join('\n')}
      </div>

      <a href="/case" class="back-link">← Cases</a>
    </article>
  </div>
</Layout>

<style>
  .admin-page {
    max-width: 1080px;
    width: 100%;
    margin: 0 auto;
    padding: 72px 48px 104px;
  }

  .admin-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 0;
    border-bottom: 1px solid var(--line);
    margin-bottom: 32px;
  }

  .admin-nav-brand {
    font-weight: 700;
    font-size: 14px;
    color: var(--foreground);
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .admin-nav-links {
    display: flex;
    gap: 16px;
  }

  .admin-nav-links a {
    font-size: 13px;
    font-weight: 600;
    color: var(--muted);
    text-decoration: none;
    padding: 6px 12px;
    border-radius: 8px;
    transition: all 120ms ease;
  }

  .admin-nav-links a:hover {
    color: var(--foreground);
    background: color-mix(in srgb, var(--card) 60%, var(--background));
  }

  .back-link {
    display: inline-block;
    font-size: 13px;
    font-weight: 700;
    color: var(--muted);
    text-decoration: none;
    margin-bottom: 24px;
    transition: color 120ms ease;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .case-article {
    padding-top: 12px;
  }

  .article-header {
    margin-bottom: 24px;
  }

  .article-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }

  .article-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.2;
    margin: 0 0 16px;
    max-width: 18ch;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 13px;
    color: var(--muted);
    padding-top: 12px;
    border-top: 1px solid var(--line);
  }

  .article-meta a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
  }

  .article-meta a:hover {
    text-decoration: underline;
  }

  .detail-thumb-wrap {
    margin-bottom: 28px;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--line) 82%, transparent);
    background: color-mix(in srgb, var(--card) 95%, transparent);
  }

  .detail-thumb {
    width: 100%;
    height: auto;
    display: block;
  }

  .article-content {
    font-size: 1.02rem;
    line-height: 1.82;
    color: var(--foreground);
  }

  .article-content p {
    margin: 0 0 18px;
  }

  @media (max-width: 720px) {
    .admin-page {
      padding: 0 18px 84px;
    }
  }
</style>


