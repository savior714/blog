---
import { getCollection } from 'astro:content';
import Layout from '../components/Layout.astro';
import Footer from '../components/Footer.astro';
import CaseThumbnail from '../components/CaseThumbnail.astro';
import ArrowRightIcon from '../components/ArrowRightIcon.astro';
import CompassIcon from '../components/CompassIcon.astro';
import HomeIcon from '../components/HomeIcon.astro';
import type { CasePost } from '../../lib/cases';

const allCases = await getCollection('cases');
const sortedCases = allCases.sort((a, b) =>
  b.data.publishedAt.localeCompare(a.data.publishedAt)
);
const totalCases = sortedCases.length;
---

<Layout title="Case Archive | Savior Lab Notes" description="바이브코딩, Local AI, Local LLM 관련 실험 기록을 모아둔 페이지입니다." />

<main class="page magazine-page">
  <nav class="top-nav">
    <a href="/" class="inline-link">
      <HomeIcon className="inline-link-icon" />
      홈으로
    </a>
  </nav>
  <header class="hero archive-hero">
    <p class="eyebrow">CASE ARCHIVE</p>
    <h1>실전 사례 모음</h1>
    <p class="lead">
      바이브코딩, Local AI, Local LLM 관련 실험 기록을 모아둔 페이지입니다.
      관심 주제부터 바로 확인해보세요.
    </p>
    <div class="archive-meta">
      <span>Total</span>
      <strong>{totalCases}</strong>
    </div>
  </header>

  <section class="featured">
    <div class="section-head">
      <h2>All Cases</h2>
      <span class="inline-link">
        <CompassIcon className="inline-link-icon" />
        최신순 정렬
      </span>
    </div>
    <div class="cards">
      {sortedCases.map((caseItem, index) => {
        const post = caseItem.data as CasePost;
        return (
          <article key={post.slug} class="card">
            <CaseThumbnail post={post} variant="card" />
            <span>{post.tag}</span>
            <h3>{`#${index + 1} ${post.title}`}</h3>
            <p>{post.summary}</p>
            <a href={`/case/${post.slug}`} class="inline-link">
              자세히 읽기
              <ArrowRightIcon className="inline-link-icon" />
            </a>
          </article>
        );
      })}
    </div>
  </section>
</main>

<Footer />
