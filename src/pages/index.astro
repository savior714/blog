---
import { getCollection } from 'astro:content';
import Layout from '../components/Layout.astro';
import Footer from '../components/Footer.astro';
import CaseThumbnail from '../components/CaseThumbnail.astro';
import ArrowRightIcon from '../components/ArrowRightIcon.astro';
import CompassIcon from '../components/CompassIcon.astro';
import type { CasePost } from '../lib/cases';

const allCases = await getCollection('cases');
const sortedCases = allCases.sort((a, b) =>
  b.data.publishedAt.localeCompare(a.data.publishedAt)
);
const featuredPosts = sortedCases.slice(0, 3).map((c) => c.data) as CasePost[];
const totalCases = sortedCases.length;
---

<Layout title="Savior Lab Notes | Build with AI, Ship with Clarity." description="바이브코딩과 로컬 AI 실험을 케이스 단위로 기록합니다. 유튜브에서 다루지 못한 구현 맥락과 설정값을 이곳에 정리합니다." />

<main class="page magazine-page">
  <section class="hero-shell">
    <header class="hero-panel">
      <p class="eyebrow">SAVIOR LAB NOTES</p>
      <h1>Build with AI, Ship with Clarity.</h1>
      <p class="lead">
        바이브코딩과 로컬 AI 실험을 케이스 단위로 기록합니다. 유튜브에서 다루지
        못한 구현 맥락과 설정값을 이곳에 정리합니다.
      </p>
      <div class="hero-actions">
        <a class="button primary" href="#featured">
          대표 사례 보기
        </a>
        <a
          class="button ghost"
          href="https://github.com/savior714/blog"
          target="_blank"
          rel="noreferrer"
        >
          GitHub
        </a>
      </div>
    </header>
    <aside class="hero-aside">
      <p class="eyebrow">THIS WEEK</p>
      <p class="hero-aside-number">{String(totalCases).padStart(2, '0')}</p>
      <p class="hero-aside-copy">Published AI building cases</p>
      <svg
        class="hero-orbit"
        viewBox="0 0 260 260"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <circle cx="130" cy="130" r="108" />
        <circle cx="130" cy="130" r="70" />
      </svg>
    </aside>
  </section>

  <section class="topics topics-editorial" aria-label="주요 주제">
    <p>핵심 주제</p>
    <ul>
      <li>Vibe Coding</li>
      <li>Local AI Workflow</li>
      <li>Local LLM Ops</li>
      <li>YouTube Deep Dive Notes</li>
    </ul>
  </section>

  <section id="featured" class="featured">
    <div class="section-head">
      <h2>Featured Case Studies</h2>
      <a href="/case" class="inline-link">
        <CompassIcon className="inline-link-icon" />
        전체 글 보기
      </a>
    </div>
    <div class="cards spotlight-cards">
      {featuredPosts.map((post, index) => (
        <article key={post.slug} class="card spotlight-card">
          <CaseThumbnail post={post} variant="card" />
          <span>{post.tag}</span>
          <h3>{`#${index + 1} ${post.title}`}</h3>
          <p>{post.summary}</p>
          <a href={`/case/${post.slug}`} class="inline-link">
            케이스 읽기
            <ArrowRightIcon className="inline-link-icon" />
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="cta cta-editorial">
    <h2>영상 보고 왔다면, 여기서 바로 이어서 보세요</h2>
    <p>
      각 글 상단에 유튜브 원본 영상과 함께 실습 코드/설정값을 함께 정리할
      예정입니다.
    </p>
  </section>
</main>

<Footer />
