---
interface Props {
  className?: string;
}

const { className = '' } = Astro.props;
---

<svg
  class={className}
  width="16"
  height="16"
  viewBox="0 0 16 16"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <circle cx="8" cy="8" r="6.75" stroke="currentColor" stroke-width="1.3" />
  <path
    d="M10.6 5.4L9.15 9.15L5.4 10.6L6.85 6.85L10.6 5.4Z"
    stroke="currentColor"
    stroke-width="1.3"
    stroke-linejoin="round"
  />
  <circle cx="8" cy="8" r="1" fill="currentColor" />
</svg>
