---
import Layout from '../../components/Layout.astro';
import { SITE_URL } from '../../config/site';
import { getCollection, getEntry, render } from 'astro:content';
import { Picture } from 'astro:assets';

export async function getStaticPaths() {
  const cases = await getCollection('cases');
  return cases.map((entry) => ({
    params: { slug: entry.id },
  }));
}

const slug = Astro.params.slug;
const entry = await getEntry('cases', slug);

if (!entry) {
  return Astro.redirect('/404');
}

const { tag, title, summary, publishedAt, youtubeUrl, thumbnail } = entry.data;

const ogImage = thumbnail || `${SITE_URL}/og-default.png`;
const ogUrl = `${SITE_URL}/case/${slug}`;

const { Content } = await render(entry);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: summary,
  datePublished: publishedAt.toISOString(),
  author: { '@type': 'Organization', name: 'Savior Lab Notes' },
  mainEntityOfPage: ogUrl,
  image: ogImage,
};
---

<Layout
  title={`${title} | Savior Lab Notes`}
  description={summary}
  ogImage={ogImage}
  ogUrl={ogUrl}
  ogType="article"
  publishedAt={publishedAt.toISOString()}
  tag={tag}
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(articleSchema)}
  />
  <div class="admin-page">
    <nav class="admin-nav">
      <a href="/" class="admin-nav-brand">Savior Lab Notes</a>
      <div class="admin-nav-links">
        <a href="/case">Cases</a>
        <a href="/editor">Editor</a>
      </div>
    </nav>

    <article class="case-article">
      <a href="/case" class="back-link text-muted">← Cases</a>

      <header class="article-header">
        <span class="article-tag text-accent">{tag}</span>
        <h1>{title}</h1>
        <div class="article-meta text-muted">
          <time>{new Date(publishedAt).toLocaleDateString('ko-KR')}</time>
          {youtubeUrl && (
            <a href={youtubeUrl} target="_blank" rel="noreferrer" class="text-accent">YouTube ↗</a>
          )}
        </div>
      </header>

      {thumbnail && (
        <div class="detail-thumb-wrap">
          <Picture src={thumbnail} alt={title} class="detail-thumb" formats={['avif', 'webp']} loading="lazy" />
        </div>
      )}

      <div class="article-content">
        <Content />
      </div>

      <a href="/case" class="back-link text-muted">← Cases</a>
    </article>
  </div>
</Layout>

<style>
  .admin-page {
    max-width: 1080px;
    width: 100%;
    margin: 0 auto;
    padding: 72px 48px 104px;
  }

  .admin-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 0;
    border-bottom: 1px solid var(--line);
    margin-bottom: 32px;
  }

  .admin-nav-brand {
    font-weight: 700;
    font-size: 14px;
    color: var(--foreground);
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .admin-nav-links {
    display: flex;
    gap: 16px;
  }

  .admin-nav-links a {
    font-size: 13px;
    font-weight: 600;
    color: var(--muted);
    text-decoration: none;
    padding: 6px 12px;
    border-radius: 8px;
    transition: all 120ms ease;
  }

  .admin-nav-links a:hover {
    color: var(--foreground);
    background: color-mix(in srgb, var(--card) 60%, var(--background));
  }

  .back-link {
    display: inline-block;
    font-size: 13px;
    font-weight: 700;
    color: var(--muted);
    text-decoration: none;
    margin-bottom: 24px;
    transition: color 120ms ease;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .case-article {
    width: 100%;
    padding-top: 12px;
  }

  .article-header {
    margin-bottom: 24px;
  }

  .article-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }

  .article-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.2;
    max-width: 100%;
    margin: 0 0 16px;

  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 13px;
    color: var(--muted);
    padding-top: 12px;
    border-top: 1px solid var(--line);
  }

  .article-meta a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
  }

  .article-meta a:hover {
    text-decoration: underline;
  }

  .detail-thumb-wrap {
    margin-bottom: 28px;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--line) 82%, transparent);
    background: color-mix(in srgb, var(--card) 95%, transparent);
  }

  .detail-thumb {
    width: 100%;
    height: auto;
    display: block;
  }

  .article-content {
    overflow-wrap: break-word;
    word-break: break-word;
    hyphens: auto;
  }

  .article-content pre {
    max-width: 100%;
    overflow-x: auto;
  }

  .article-content code {
    max-width: 100%;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .article-content table {
    max-width: 100%;
    display: block;
    overflow-x: auto;
  }

  @media (max-width: 720px) {
    .admin-page {
      padding: 0 18px 84px;
    }
  }
</style>


